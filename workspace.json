{
  "description": "Workspace manifest. scripts/init.* clones each repo and creates mcp-test symlinks.",
  "repos": [
    {
      "name": "agent-marketplace",
      "path": "agent-marketplace",
      "remote": "git@github.com:Seretos/agent-marketplace.git",
      "branch": "main"
    },
    {
      "name": "agent-vdesktop",
      "path": "plugins/agent-vdesktop",
      "remote": "git@github.com:Seretos/agent-vdesktop.git",
      "branch": "main"
    },
    {
      "name": "agent-vdesktop-skill",
      "path": "plugins/agent-vdesktop-skill",
      "remote": "git@github.com:Seretos/agent-vdesktop-skill.git",
      "branch": "main"
    },
    {
      "name": "agent-project-issues",
      "path": "plugins/agent-project-issues",
      "remote": "git@github.com:Seretos/agent-project-issues.git",
      "branch": "main"
    },
    {
      "name": "agent-worktree",
      "path": "plugins/agent-worktree",
      "remote": "git@github.com:Seretos/agent-worktree.git",
      "branch": "main"
    },
    {
      "name": "lib-python-config",
      "path": "libs/lib-python-config",
      "remote": "git@github.com:Seretos/lib-python-config.git",
      "branch": "main"
    },
    {
      "name": "lib-python-projects",
      "path": "libs/lib-python-projects",
      "remote": "git@github.com:Seretos/lib-python-projects.git",
      "branch": "main"
    },
    {
      "name": "lib-python-vdesktop",
      "path": "libs/lib-python-vdesktop",
      "remote": "git@github.com:Seretos/lib-python-vdesktop.git",
      "branch": "main"
    },
    {
      "name": "agent-python-developer-ticket-workflow",
      "path": "plugins/agent-python-developer-ticket-workflow",
      "remote": "git@github.com:Seretos/agent-python-developer-ticket-workflow.git",
      "branch": "main"
    },
    {
      "name": "agent-mcp-tester",
      "path": "plugins/agent-mcp-tester",
      "remote": "git@github.com:Seretos/agent-mcp-tester.git",
      "branch": "main"
    }
  ],
  "mcpTestSymlinks": [
    { "from": "mcp-test/plugins/agent-vdesktop",       "to": "plugins/agent-vdesktop" },
    { "from": "mcp-test/plugins/agent-vdesktop-skill", "to": "plugins/agent-vdesktop-skill" },
    { "from": "mcp-test/plugins/agent-project-issues", "to": "plugins/agent-project-issues" },
    { "from": "mcp-test/plugins/agent-worktree",       "to": "plugins/agent-worktree" },
    { "from": "mcp-test/plugins/agent-mcp-tester",     "to": "plugins/agent-mcp-tester" }
  ]
}
